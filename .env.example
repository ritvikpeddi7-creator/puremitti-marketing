# Video processing scaffold - .env example (updated)

# Redis URL used by BullMQ
REDIS_URL=redis://redis:6379

# AWS S3 configuration (or S3-compatible endpoint like MinIO)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=videos
S3_ENDPOINT=http://minio:9000

# JWT secret for demo auth (change in production)
JWT_SECRET=super-secret-change-me

# Server port (optional)
PORT=3000
